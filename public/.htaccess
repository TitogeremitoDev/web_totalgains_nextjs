# ─────────────────────────────────────────────────────
# TotalGains — .htaccess para Hostinger (LiteSpeed)
# Next.js Static Export con trailingSlash: true
# ─────────────────────────────────────────────────────

RewriteEngine On

# 1. Forzar HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# 2. Página 404 de Next.js
ErrorDocument 404 /404/index.html

# 3. Desactivar listado de directorios
Options -Indexes
