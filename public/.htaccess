# ── Routing Next.js estático ─────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 410 Gone — APK eliminado
    Redirect 410 /TotalGains.apk

    # 301 redirects — blogs antiguos sin contenido actual
    Redirect 301 /blog/app-entrenamiento-personalizado /blog/ia-entrenador-personal-rutinas-dietas/
    Redirect 301 /blog/app-entrenamiento-personalizado/ /blog/ia-entrenador-personal-rutinas-dietas/
    Redirect 301 /blog/gestion-clientes-entrenador-personal /gestion-clientes-fitness/
    Redirect 301 /blog/gestion-clientes-entrenador-personal/ /gestion-clientes-fitness/

    # Añadir trailing slash a rutas sin extensión
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !/$
    RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
    RewriteRule ^(.+)$ /$1/ [R=301,L]

    # Servir index.html para directorios
    DirectoryIndex index.html
    Options -Indexes
</IfModule>

# ── Compresión ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── Cache-Control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ── Tipos MIME correctos ─────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType font/woff2 .woff2
</IfModule>

# ── Seguridad básica ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── App autenticada — NO indexar en SEO ni AI ────────────────────────────────
# SetEnvIf SÍ funciona en .htaccess (al contrario que LocationMatch).
# Marca solo las URLs /app/ y /api/ con env, y luego aplica X-Robots-Tag a esas.
<IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/app/" NOINDEX_APP=1
    SetEnvIf Request_URI "^/api/"  NOINDEX_API=1
</IfModule>

<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet" env=NOINDEX_APP
    Header set X-Robots-Tag "noindex, nofollow" env=NOINDEX_API
</IfModule>
